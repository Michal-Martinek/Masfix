
%include "memory"
%include "math"
%include "io"
%include "structs"
%include "control"
%include "procedures"
%include "pair"

%macro separate_errs(num) {
	%nop(!print_endl(outu %num))
	%(("------------ ")(%num)(" ------------"))
}

; testing struct mis-definition
%namespace more_in_one {
	%struct:begin()
	%struct:field(a, 1)
	%1st
	%struct:begin()
	%2nd
	%struct:end()
	%3rd
	%struct:begin()
}
%nop(!separate_errs(1))

%struct:end()
%namespace no_begin {
	%struct:field(lala, 2)
	%
	%struct:end()
}
%nop(!separate_errs(2))

%namespace more_ends {
	%struct:begin()
	%struct:field(lala, 2)
	%struct:end()
	%struct:end()
}
%nop(!separate_errs(3))

; testing proper def on ds:pair
%include "ds/pair"
%(%pair:struct_id)
%(%pair:first)
%(%pair:second)
%(%pair:third)
%(%pair:sizeof)

%nop(!print_spaced(
	mov %MEMORY_LAYOUT:SEG_TEMP
	%pair:at(first)
	outuh
))
%nop(!print_endl(
	mov %MEMORY_LAYOUT:SEG_TEMP
	%pair:at(second)
	%print_spaced(outuh) ;
	%pair:reset(second)
	outuh ;
))

%include "debug"

%macro testPair() {
	; must be defined inside - ctime calls don't work yet
	%void_func{ testPair, 0, !op(t, 2, %pair:sizeof),
		%seg:local(0,
			%pair:set(first, 6)
			%pair:set(second, 4)
		)
		%seg:local(%pair:sizeof,
			%pair:set(first, 4)
			%pair:set(second, 7)
			%pair:do_at(second, strs 1)
		)
		%print_endl(
			outc 'P'
			%seg:push_addr(%local, 0)
			%callWith1Arg(memdump, 4)
		)

		%seg:local(%pair:sizeof,
			%pair:swapPair()
		)

		%seg:push_addr(%local, 0)
		%seg:push_addr(%local, %pair:sizeof)
		%call(pair_compare_eq)
		%print_spaced(
			%stack:pop()
			outur
		)

		; test copy semantics
		%seg:push_addr(%local, 0)
		%pair:shallow_copy()
		%print_spaced( outum )

		%stack:push(0)
		%stack:push(0)
		%stack:push(',')
		%call(pair_print)

		%stack:push(%MEMORY_LAYOUT:SEG_HEAP)
		%stack:push(8)
		%call(memdump)
	}
	%call(testPair)
}
%nop(!testPair())
